# Базовый URL сайта (для canonical, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://pogoda-zapolyarya.ru

# Контактный User-Agent для api.met.no (требование TOS).
# ВАЖНО: укажи реальный контакт. MET блокирует (403) UA с example.com!
MET_USER_AGENT=PogodaZapolyarya/1.0 (+https://pogoda-zapolyarya.ru; contact@pogoda-zapolyarya.ru)

# GigaChat (Сбер) — AI-сводки. Доступен из РФ, без геоблока.
# «Ключ авторизации» (base64) из кабинета: https://developers.sber.ru/studio
GIGACHAT_AUTH_KEY=

# Scope: GIGACHAT_API_PERS (физлица) | GIGACHAT_API_B2B | GIGACHAT_API_CORP
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# Необязательно: модель (GigaChat | GigaChat-Pro | GigaChat-Max)
# GIGACHAT_MODEL=GigaChat

# Админка (/admin). Без ADMIN_PASSWORD админка недоступна (вход всегда отклоняется).
ADMIN_PASSWORD=
# Секрет подписи сессионной куки (любая длинная случайная строка, напр. `openssl rand -hex 32`).
# Если не задан — деградирует на ADMIN_PASSWORD.
ADMIN_SESSION_SECRET=
