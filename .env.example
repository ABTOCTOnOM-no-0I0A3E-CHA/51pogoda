# Базовый URL сайта (для canonical, sitemap, OpenGraph)
NEXT_PUBLIC_SITE_URL=https://51pogoda.ru

# Контактный User-Agent для api.met.no (требование TOS).
# ВАЖНО: укажи реальный контакт. MET блокирует (403) UA с example.com!
MET_USER_AGENT=Normeteo/1.0 (+https://51pogoda.ru; contact@51pogoda.ru)

# ИИ-сводка через OpenRouter (модель — DeepSeek v4 Flash).
# Без ключа — детерминированный fallback без LLM.
OPENROUTER_API_KEY=
# Модель OpenRouter (по умолчанию deepseek/deepseek-chat)
OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# Ключ для крона предгенерации сводок (любая строка).
# Используется в /api/cron/daily-summary?key=...
CRON_SECRET=

# Прокси для Open-Meteo (если api.open-meteo.com недоступен напрямую, напр. из РФ).
# Раскомментируй и укажи URL твоего прокси-бекенда.
# Если прокси в отдельном докере — используй host.docker.internal:
# OPEN_METEO_PROXY=http://host.docker.internal:3001/forecast

# Админка (/admin). Без ADMIN_PASSWORD админка недоступна (вход всегда отклоняется).
ADMIN_PASSWORD=
# Секрет подписи сессионной куки (любая длинная случайная строка, напр. `openssl rand -hex 32`).
# Если не задан — деградирует на ADMIN_PASSWORD.
ADMIN_SESSION_SECRET=
